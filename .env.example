# Example environment variables for GridFlex backend (do NOT commit real keys)

# Enable or disable calling the hosted coordination kernel API
COORD_KERNEL_ENABLED=false

# Base URL for the hosted coordination kernel API
COORD_KERNEL_API_URL=https://amartyagroup.com/coordination-api

# Server-side API key for the coordination kernel (replace locally, do not commit)
COORD_KERNEL_API_KEY=replace-with-server-side-key

# Optional NVIDIA hosted NIM text explanation settings (replace locally, do not commit keys)
NVIDIA_API_KEY=replace-with-build-nvidia-key
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=nvidia/nemotron-3-ultra-550b-a55b
NIM_TIMEOUT_SECONDS=20
